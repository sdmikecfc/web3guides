# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The root domain (without leading dot)
NEXT_PUBLIC_ROOT_DOMAIN=web3guides.com

# For local dev, set your local test host
# e.g. eth.localhost:3000 will resolve to subdomain "eth"
NEXT_PUBLIC_DEV_ROOT_DOMAIN=localhost:3000
